{
  "name": "3dmaze",
  "version": "1.0.0",
  "description": "Responsive 3D maze game built with React, Three.js, and GSAP.",
  "private": true,
  "main": "index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test playtest-smoke.spec.js",
    "qa:campaign:static": "tsx scripts/qa-campaign-audit.ts",
    "qa:campaign": "playwright test playtest-campaign-solvability.spec.ts && npm run qa:campaign:static",
    "qa:enemy:static": "tsx scripts/qa-enemy-audit.ts",
    "qa:enemy:e2e": "tsx scripts/qa-enemy-e2e.ts",
    "qa:enemy": "npm run qa:enemy:static && npm run qa:enemy:e2e",
    "bench": "tsx scripts/bench-enemy-perf.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": "22.x"
  },
  "type": "module",
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vitejs/plugin-react": "^6.0.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.8.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "three": "^0.184.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "tsx": "^4.19.4",
    "vitest": "^4.1.5"
  }
}
